# Tạo API key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Có thể đổi model nếu tài khoản của bạn hỗ trợ model khác.
OPENAI_MODEL=gpt-5-mini

# Tổng token tối đa gồm cả suy luận và nội dung hiển thị.
OPENAI_MAX_OUTPUT_TOKENS=3000

# Chỉ dùng khi chạy local; không cần thêm hai biến này trên Vercel.
PORT=3000
HOST=127.0.0.1
